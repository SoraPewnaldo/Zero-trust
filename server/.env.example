# =====================================================
# ZeroIAM Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =====================================================

# Environment: development | production | test
NODE_ENV=development

# Server
PORT=3001

# Database
# Dev: mongodb://localhost:27017/zeroiam_dev
# Docker: mongodb://mongodb:27017/zeroiam_dev
MONGODB_URI=mongodb://localhost:27017/zeroiam_dev

# JWT
# IMPORTANT: Change this to a strong, random secret before EVER deploying!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET
JWT_EXPIRES_IN=8h

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173

# Trust Engine (Python PDP)
TRUST_ENGINE_URL=http://localhost:5000/scan
TRUST_ENGINE_TIMEOUT=8000
