{
    "name": "zeroiam-backend",
    "version": "1.0.0",
    "description": "ZeroIAM Zero Trust Backend API",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "dev": "node --watch src/server.js",
        "start": "node src/server.js",
        "init-db": "node src/scripts/initDb.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "build": "node --check src/server.js && echo Build validation passed",
        "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src --ext .js -c .eslintrc.cjs"
    },
    "keywords": [
        "zero-trust",
        "iam",
        "security"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.13.5",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.3.2",
        "express-validator": "^7.0.1",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "ua-parser-js": "^1.0.37",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "eslint": "^8.56.0",
        "supertest": "^6.3.3",
        "vitest": "^1.1.1"
    }
}
