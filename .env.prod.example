# =====================================================
# ZeroIAM — Production Environment Variables
# =====================================================
# 1. Copy this file: cp .env.prod.example .env.prod
# 2. Fill in ALL values marked with <CHANGE_THIS>
# 3. NEVER commit .env.prod to git
# =====================================================

# ── Server ─────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ────────────────────────────────────────
# MongoDB runs inside Docker on the prod-network.
# Do NOT change the hostname (mongodb = container name).
MONGODB_URI=mongodb://mongodb:27017/zeroiam_prod

# ── JWT Secret ──────────────────────────────────────
# REQUIRED: Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Then paste the result below.
JWT_SECRET=<CHANGE_THIS_TO_A_STRONG_64_CHAR_HEX_SECRET>
JWT_EXPIRES_IN=8h

# ── CORS ────────────────────────────────────────────
# Set to your EC2 public IP or domain.
# Examples:
#   http://13.233.45.67          (bare IP)
#   https://zeroiam.yourdomain.com   (domain with SSL)
CORS_ORIGIN=http://<YOUR_EC2_PUBLIC_IP_OR_DOMAIN>

# ── Trust Engine ────────────────────────────────────
# Trust Engine runs inside Docker — DO NOT change the hostname.
TRUST_ENGINE_URL=http://trust_engine:5000/scan
TRUST_ENGINE_TIMEOUT=10000
